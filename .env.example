# Choose your storage mode: "local", "supabase" or "firebase"
VITE_STORAGE_MODE=supabase

# If you chose Supabase, insert your URL and anon key here
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# if you chose Firebase, insert your config values here
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=